# ======== Configuration Discord ========
DISCORD_TOKEN=your_discord_bot_token_here
ARCADIUS_TOKEN=your_arcadius_bot_token_here_optional

ARCADIUS_CHANNEL_ID=your_arcadius_channel_id_here

# ======== Main Gemini API Keys (Chat) ========
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_optional
GEMINI_API_KEY_3=your_third_gemini_api_key_optional

# ======== Memory Pool (Dedicated Gemini Key) ========
GEMINI_API_KEY_MEMORY=your_memory_gemini_api_key_here

# ======== Help Detection System ========
# Support channel IDs for help detection (comma-separated, no spaces)
SUPPORT_CHANNEL_IDS=1367176787867471883,1348235685047566346

# LLM Provider for Help Detection (choose ONE):
# OPTION 1: Gemini (Free tier available)
GEMINI_API_KEY_SUPPORT=AIzaSy_your_gemini_support_key_here

# OPTION 2: Groq (Completely free, very fast!) - RECOMMENDED
GROQ_API_KEY=gsk_your_groq_key_here

# OPTION 3: OpenRouter (Multiple models, ~$3 free credit)
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# ======== Logging ========
LOG_LEVEL=info